# ── 외부 API 키 ───────────────────────────────────────────
KAKAO_REST_API_KEY=
GEMINI_API_KEY=

# ── 서버 설정 ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=8888

# ── 관리자 인증 ───────────────────────────────────────────
# POST /api/admin/reset/{table} 호출 시 X-Admin-Key 헤더에 사용
ADMIN_SECRET_KEY=

# ── DB 설정 (로컬 개발용) ─────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=roomitai

# ── DB 설정 (Railway MySQL 플러그인 자동 주입) ────────────
# Railway 대시보드에서 MySQL 플러그인을 추가하면 아래 값이 자동으로 설정됩니다.
# 직접 입력할 필요 없음.
# MYSQLHOST=
# MYSQLPORT=
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=
